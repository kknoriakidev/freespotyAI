{
  "name": "spotifree",
  "version": "1.0.0",
  "description": "Spotifree - a Spotify-like music player with custom uploads and GIF support",
  "main": "main.js",
  "scripts": {
    "start": "node server/index.js",
    "electron": "electron main.js",
    "dev": "concurrently \"npm run start\" \"npm run electron\"",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64"
  },
  "author": "kknoriakidev",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2"
  },
  "build": {
    "appId": "com.kknoriakidev.spotifree",
    "productName": "Spotifree",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server/**/*",
      "public/**/*",
      "package.json",
      "!server/uploads/*",
      "!server/db.json"
    ],
    "extraResources": [
      {
        "from": "server/uploads",
        "to": "uploads",
        "filter": [".gitkeep"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Spotifree-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Spotifree"
    }
  }
}
