{
  "name": "spotifree",
  "version": "1.0.0",
  "description": "Spotifree - free Spotify-style music player with custom uploads and GIF covers",
  "main": "main.js",
  "scripts": {
    "start": "node server/index.js",
    "electron": "electron main.js",
    "dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && npm run electron\"",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "author": "kknoriakidev",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.kknoriakidev.spotifree",
    "productName": "Spotifree",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server/**/*",
      "public/**/*",
      "package.json",
      "!server/uploads/*",
      "!server/db.json"
    ],
    "extraResources": [
      {
        "from": "server/uploads",
        "to": "uploads",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Spotifree-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Spotifree"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.music"
    }
  }
}
